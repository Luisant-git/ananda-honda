generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id          Int      @id @default(autoincrement())
  branchName  String
  branchCode  String   @unique
  networkType String?
  inventoryLocation String?
  brand       String   @default("BIGWINGS")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}


model Customer {
  id        Int     @id @default(autoincrement())
  custId    String  @unique
  name      String
  contactNo String
  address   String
  location  String?
  pincode   String?
  status    String

  enquiryDate       DateTime?
  vehicleModel      String? // crm vehicle model
  color             String?
  variant           String?
  interestLevel     String?
  purchaseType      String?
  exchangeDetails   String?
  branch            String?
  assignedExecutive String?
  remarks           String?

  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  paymentCollections        PaymentCollection[]
  servicePaymentCollections ServicePaymentCollection[]
  brand String @default("BIGWINGS")
  branchCode String?
}

model PaymentMode {
  id                 Int                 @id @default(autoincrement())
  paymentMode        String
  status             String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  typeOfPayments     TypeOfPayment[]
  paymentCollections PaymentCollection[]
  brand String @default("BIGWINGS")
}

model TypeOfPayment {
  id                 Int                 @id @default(autoincrement())
  paymentModeId      Int
  typeOfMode         String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  paymentMode        PaymentMode         @relation(fields: [paymentModeId], references: [id])
  paymentCollections PaymentCollection[]
  brand String @default("BIGWINGS")
}

model ServiceTypeOfCollection {
  id                        Int                        @id @default(autoincrement())
  typeOfCollect             String
  status                    String
  disableVehicleModel       Boolean                    @default(false)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  servicePaymentCollections ServicePaymentCollection[]
  additionalPlanPayments    ServicePaymentCollection[] @relation("AdditionalPlanRelation")
  brand String @default("BIGWINGS")
}

model TypeOfCollection {
  id                  Int                 @id @default(autoincrement())
  typeOfCollect       String
  status              String
  disableVehicleModel Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  paymentCollections  PaymentCollection[]
  brand String @default("BIGWINGS")
}

model VehicleModel {
  id                        Int                        @id @default(autoincrement())
  model                     String
  status                    String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  paymentCollections        PaymentCollection[]
  servicePaymentCollections ServicePaymentCollection[]
  brand String @default("BIGWINGS")
}

model PaymentCollection {
  id                 Int               @id @default(autoincrement())
  date               DateTime
  receiptNo          String            @unique
  refNo              String?
  customerId         Int
  recAmt             Float
  paymentModeId      Int
  paymentType        String            @default("booking")
  typeOfPaymentId    Int?
  typeOfCollectionId Int?
  vehicleModelId     Int?
  enteredBy          Int?
  remarks            String?
  deletedAt          DateTime?
  deletedBy          Int?
  cancelledAt        DateTime?
  cancelledBy        Int?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  customer           Customer          @relation(fields: [customerId], references: [id])
  paymentMode        PaymentMode       @relation(fields: [paymentModeId], references: [id])
  typeOfPayment      TypeOfPayment?    @relation(fields: [typeOfPaymentId], references: [id])
  typeOfCollection   TypeOfCollection? @relation(fields: [typeOfCollectionId], references: [id])
  vehicleModel       VehicleModel?     @relation(fields: [vehicleModelId], references: [id])
  user               User?             @relation(fields: [enteredBy], references: [id])
  deletedByUser      User?             @relation("DeletedPayments", fields: [deletedBy], references: [id])
  cancelledByUser    User?             @relation("CancelledPayments", fields: [cancelledBy], references: [id])
  brand String @default("BIGWINGS")
  branchCode String?
}

model ServicePaymentMode {
  id                        Int                        @id @default(autoincrement())
  paymentMode               String
  status                    String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  serviceTypeOfPayments     ServiceTypeOfPayment[]
  servicePaymentCollections ServicePaymentCollection[]
  brand String @default("BIGWINGS")
}

model ServiceTypeOfPayment {
  id                        Int                        @id @default(autoincrement())
  paymentModeId             Int
  typeOfMode                String
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  paymentMode               ServicePaymentMode         @relation(fields: [paymentModeId], references: [id])
  servicePaymentCollections ServicePaymentCollection[]
  brand String @default("BIGWINGS")
}

model ServicePaymentCollection {
  id                        Int                      @id @default(autoincrement())
  date                      DateTime
  receiptNo                 String                   @unique
  refNo                     String?
  customerId                Int
  totalAmt                  Float?
  recAmt                    Float
  hasAdditionalPlan         Boolean?                 @default(false)
  additionalPlanAmount      Float?                   @default(0)
  additionalPlanDetails     Json?
  paymentType               String                   @default("full payment")
  paymentTypeId             Int?
  paymentTypeMaster         PaymentType?             @relation(fields: [paymentTypeId], references: [id])
  // Default to 'pending' to avoid accidental completed state when frontend omits this field
  paymentStatus             String                   @default("pending")
  vehicleNumber             String?
  paymentModeId             Int
  typeOfPaymentId           Int?
  serviceTypeOfCollectionId Int?
  vehicleModelId            Int?
  enteredBy                 Int?
  remarks                   String?
  jobCardNumber             String?
  serviceTypeId             Int?
  paymentSessions           Json                     @default("[]")
  selectedParts             Json?                    @default("[]")
  deletedAt                 DateTime?
  deletedBy                 Int?
  cancelledAt               DateTime?
  cancelledBy               Int?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  customer                  Customer                 @relation(fields: [customerId], references: [id])
  paymentMode               ServicePaymentMode       @relation(fields: [paymentModeId], references: [id])
  typeOfPayment             ServiceTypeOfPayment?    @relation(fields: [typeOfPaymentId], references: [id])
  serviceTypeOfCollection   ServiceTypeOfCollection? @relation(fields: [serviceTypeOfCollectionId], references: [id])
  additionalPlanCollections ServiceTypeOfCollection[] @relation("AdditionalPlanRelation")
  serviceTypeRelation       ServiceType?             @relation(fields: [serviceTypeId], references: [id])
  vehicleModel              VehicleModel?            @relation(fields: [vehicleModelId], references: [id])
  user                      User?                    @relation(fields: [enteredBy], references: [id])
  deletedByUser             User?                    @relation("DeletedServicePayments", fields: [deletedBy], references: [id])
  cancelledByUser           User?                    @relation("CancelledServicePayments", fields: [cancelledBy], references: [id])
  brand String @default("BIGWINGS")
  branchCode String?
}

model PaymentType {
  id                        Int                        @id @default(autoincrement())
  name                      String                     @unique
  isActive                  Boolean                    @default(true)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  servicePaymentCollections ServicePaymentCollection[]
  brand String @default("BIGWINGS")
}

model User {
  id                        Int                        @id @default(autoincrement())
  username                  String                     @unique
  password                  String
  role                      Role
  isActive                  Boolean                    @default(true)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  paymentCollections        PaymentCollection[]
  deletedPayments           PaymentCollection[]        @relation("DeletedPayments")
  cancelledPayments         PaymentCollection[]        @relation("CancelledPayments")
  servicePaymentCollections ServicePaymentCollection[]
  deletedServicePayments    ServicePaymentCollection[] @relation("DeletedServicePayments")
  cancelledServicePayments  ServicePaymentCollection[] @relation("CancelledServicePayments")
  paymentTransactions       PaymentTransaction[]
  brand String @default("BIGWINGS")
  branchId                  Int?
  branch                    Branch?                  @relation(fields: [branchId], references: [id])
  branchCode                String?
}

model MenuPermission {
  id          Int      @id @default(autoincrement())
  role        Role     @unique
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  brand String @default("BIGWINGS")
}

model FeedbackNotificationSetting {
  id           Int      @id @default(autoincrement())
  role         String   @unique
  mobileNumber String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  brand String @default("BIGWINGS")
}


enum Role {
  SUPER_ADMIN
  ADMIN
  DEVELOPER
  ACCOUNTS
  PART_EXECUTIVE
  BILLING_EXECUTIVE
  CASHIER_SALES
  CASHIER_SERVICE
}

model Enquiry {
  id            Int      @id @default(autoincrement())
  customerName  String?
  enquiryType   String
  mobileNumber  String
  vehicleModel  String?
  leadSources   String[]
  executiveName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  brand String @default("BIGWINGS")
  branchCode String?
}

model SalesInvoice {
  id                Int                  @id @default(autoincrement())
  customerName      String
  contactInfo       String
  referenceNo       String?
  vehicleRegNo      String?
  vehicleModel      String?
  assignedTo        String?
  address1          String?
  address2          String?
  city              String?
  state             String?
  zipCode           String?
  actualDeliverDate DateTime?
  account           String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  reminderLogs      ServiceReminderLog[]

  @@index([contactInfo])
  @@index([vehicleRegNo])
  brand String @default("BIGWINGS")
  branchCode String?
}

model ServiceJobCard {
  id                    Int          @id @default(autoincrement())
  jobCardNumber         String       @unique // This is used for matching
  registrationNumber    String
  customerName          String?
  mobileNumber          String?
  vehicleDetails        String?
  serviceId             Int?
  serviceType           ServiceType? @relation(fields: [serviceId], references: [id])
  closedDate            DateTime?
  status                String       @default("Pending")
  labourRevenue         Float?       @default(0)
  partsRevenue          Float?       @default(0)
  lubesRevenue          Float?       @default(0)
  accessoriesRevenue    Float?       @default(0)
  totalRevenue          Float?       @default(0)
  amc                   Boolean      @default(false)
  oil                   Boolean      @default(false)
  battery               Boolean      @default(false)
  tyre                  Boolean      @default(false)
  painting              Boolean      @default(false)
  frameNumber           String?
  invoiceNumber         String?
  currentKM             Float?
  otpNo                 String?
  feedback              String?
  amcStartDate          DateTime?
  amcEndDate            DateTime?
  estimatedDeliveryDate DateTime?
  branchCode            String?
  mainCode              String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([mobileNumber])
  @@index([registrationNumber])
  @@index([closedDate])
  brand String @default("BIGWINGS")
  // branchCode is already present in this model
}

model ServiceType {
  id              Int                        @id @default(autoincrement())
  name            String                     @unique
  status          String
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  serviceJobCard  ServiceJobCard[]
  servicePayments ServicePaymentCollection[]
  brand String @default("BIGWINGS")
}

model ServiceTypeOfPart {
  id         Int       @id @default(autoincrement())
  partNo     String    @unique
  partName   String // for part description
  Model      String?
  status     String    @default("ORDERED")
  statusDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  brand String @default("BIGWINGS")
}

model Location {
  id           Int      @id @default(autoincrement())
  regionname   String
  divisionname String
  officename   String
  pincode      String
  district     String
  statename    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  brand String @default("BIGWINGS")
}

model ServiceReminderLog {
  id             Int      @id @default(autoincrement())
  salesInvoiceId Int
  serviceType    String // 'FREE_SERVICE_1', 'FREE_SERVICE_2', 'FREE_SERVICE_3'
  reminderNumber Int // 1 or 2 (first reminder or second reminder)
  reminderDate   DateTime
  scheduledDate  DateTime
  sentAt         DateTime @default(now())
  status         String // 'PENDING', 'SENT', 'FAILED'
  errorMessage   String?
  createdAt      DateTime @default(now())

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id])

  @@unique([salesInvoiceId, serviceType, reminderNumber])
  @@index([salesInvoiceId])
  @@index([status])
  @@index([scheduledDate])
  brand String @default("BIGWINGS")
}

model PineLabsConfig {
  id            Int      @id @default(autoincrement())
  type          String   @default("sale") // "sale" or "service"
  merchantId    String
  securityToken String
  clientId      String
  storeId       String
  hardwareSn    String?
  environment   String   @default("UAT") // UAT or Production
  status        String   @default("Active") // Active or Inactive
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  brand String @default("BIGWINGS")
}

model PaymentTransaction {
  id            Int      @id @default(autoincrement())
  transactionId String   @unique
  invoiceId     String?
  customerName  String?
  mobileNumber  String?
  amount        Float
  paymentMode   String?
  status        String   @default("Pending") // Pending, Success, Failed, Cancelled
  responseData  Json?
  machineType   String   @default("sale") // "sale" or "service"
  createdBy     Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [createdBy], references: [id])
  brand String @default("BIGWINGS")
  branchCode String?
}
